# Copy to .env and fill in when you reach Stage 2 (enrichment).
# Stage 1 (directory scrape + site) needs NONE of these.

# Firecrawl — used by phase2_discover (web search) and phase4_extract (scrape/extract)
FIRECRAWL_API_KEY=

# Anthropic Claude — reasoning layer only (identity resolution, structuring)
ANTHROPIC_API_KEY=

# People Data Labs — structured person enrichment (charged per match, ~$0.28).
# Optional: if unset, the PDL step is skipped and the rest of the run is unaffected.
PDL_API_KEY=

# GNews — public news mentions by name (flat monthly subscription, not per-call).
# Optional: if unset, the "In the news" step is skipped.
GNEWS_API_KEY=

# Perplexity (Sonar) — LLM web-search for person news/info discovery.
# Optional: used by the news-discovery experiment (news_experiment.py) and, if
# adopted, the enrichment news pass. Key: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=
