# Secrets
.env
.env.local

# Python
pipeline/.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/

# Data — DB and caches are generated, not committed. *.db.bak* also covers
# ad-hoc backups like titans.db.bak-before-wipe (which the bare *.db.bak misses)
# — these hold the full scraped-PII corpus and must never be committed.
pipeline/data/*.db
pipeline/data/*.db.bak*
pipeline/data/*.db-journal
pipeline/data/*.db-wal
pipeline/data/*.db-shm
pipeline/data/cache/

# Roster + research datasets — contain real names (the public class directory
# parsed into rows, plus research targets/logs). Never commit; the pipeline
# regenerates these from your own source data.
pipeline/data/*.csv
pipeline/data/*.jsonl
pipeline/data/*_targets.json
pipeline/data/deep_pass_*

# Ad-hoc run logs and probe output (scraped names/results; regenerated per run)
pipeline/data/run_*.log
pipeline/data/sonar_*.txt
pipeline/data/people_search_run.txt

# Runtime spend logs (append-only, regenerated at runtime)
pipeline/data/cost_log.jsonl
pipeline/data/chat_cost_log.jsonl
pipeline/data/quality_log.jsonl
pipeline/data/scorecard.jsonl

# Experiment report artifact (regenerated by news_experiment.py)
pipeline/data/news_experiment.md

# Keep snapshots dir but not its contents (raw HTML can be large)
pipeline/data/snapshots/*
!pipeline/data/snapshots/.gitkeep

# Web bundled DB: commit ONLY the synthetic sample.db. The real titans.db is
# PII and must NEVER be committed to this open-source repo. A production deploy
# gets the real DB at build time via TITANS_DB_URL (see web/scripts/sync-db.mjs).
web/data/*.db
!web/data/sample.db
web/data/*.db-shm
web/data/*.db-wal
web/data/*.db-journal

# Node / Next.js
node_modules/
web/.next/
web/out/
web/.turbo/
*.tsbuildinfo

# Test / coverage artifacts
web/coverage/
web/test-results/
web/playwright-report/

# Claude / editor local state (machine/session — never track)
.claude/scheduled_tasks.lock
**/.claude/launch.json

# OS
.DS_Store
