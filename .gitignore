# Secrets
.env
.env.local

# Python
pipeline/.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/

# Data — DB and caches are generated, not committed
pipeline/data/*.db
pipeline/data/*.db.bak
pipeline/data/*.db-journal
pipeline/data/*.db-wal
pipeline/data/*.db-shm
pipeline/data/cache/

# Runtime spend logs (append-only, regenerated at runtime)
pipeline/data/cost_log.jsonl
pipeline/data/chat_cost_log.jsonl
pipeline/data/quality_log.jsonl

# Experiment report artifact (regenerated by news_experiment.py)
pipeline/data/news_experiment.md

# Keep snapshots dir but not its contents (raw HTML can be large)
pipeline/data/snapshots/*
!pipeline/data/snapshots/.gitkeep

# Bundled DB sidecars — commit only web/data/titans.db, never its WAL files
web/data/*.db-shm
web/data/*.db-wal
web/data/*.db-journal

# Node / Next.js
node_modules/
web/.next/
web/out/
web/.turbo/
*.tsbuildinfo

# Test / coverage artifacts
web/coverage/
web/test-results/
web/playwright-report/

# Claude runtime lock (machine/session state — never track)
.claude/scheduled_tasks.lock

# OS
.DS_Store
