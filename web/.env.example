# Copy this file to .env.local (gitignored) and fill in the real value.
# NEVER commit .env.local or the actual key.

# Anthropic API key used by the public alumni chat endpoint (/api/chat).
# The chat uses Claude Haiku with a hard $100/month spend cap + kill switch.
ANTHROPIC_API_KEY=

# ── Multi-instance / serverless deploy (Vercel) ──────────────────────────────
# Without these, the app uses an in-memory rate limiter + a file-based cost log,
# which are correct ONLY on a single always-on instance. On Vercel (many
# instances) set the Upstash vars so rate limiting and the monthly spend cap are
# shared and accurate. Local dev works fine with them unset.

# Upstash Redis (REST). Create a free DB at https://upstash.com and paste both.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Secret for signing the chat page token (the lightweight endpoint gate).
# MUST be set in production — an unset secret makes tokens forgeable. Any long
# random string works, e.g. `openssl rand -base64 32`.
CHAT_TOKEN_SECRET=

# Optional: extra origins allowed to call /api/chat (comma-separated). The
# deployment's own origin is always allowed; set this only for custom domains.
# ALLOWED_ORIGIN=https://titans.example,https://www.titans.example

# Optional: override the read-only SQLite path. Defaults to ./data/titans.db
# (the snapshot bundled by `npm run sync-db`), falling back to the pipeline copy.
# TITANS_DB_PATH=
