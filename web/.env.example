# Environment variables for the Titans web app (web/).
# Copy to .env.local (gitignored) and fill in real values. NEVER commit secrets.
#
# Quick map:
#   • The SITE (directory, Overview, insights, KPIs) needs NOTHING here — it
#     reads the bundled read-only DB. Deploy with zero env vars and it works.
#   • The CHAT feature (/api/chat) needs the four CHAT vars below, as a set.
#   • Everything under OPTIONAL has a safe default — leave unset unless noted.

# ─────────────────────────────────────────────────────────────────────────────
# CHAT FEATURE  (set all four together when you want chat live; the site itself
# works without them)
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic API key for the public alumni chat endpoint (/api/chat). Chat uses
# Claude Haiku behind a hard $100/month spend cap + kill switch.
# Missing → chat doesn't work (the rest of the site is unaffected).
ANTHROPIC_API_KEY=

# Secret for signing the chat page token (the lightweight endpoint gate).
# MUST be set in production — an unset secret makes the gate forgeable.
# Any long random string, e.g. `openssl rand -base64 32`.
CHAT_TOKEN_SECRET=

# Upstash Redis (REST) — shared rate limiter + shared monthly spend cap.
# REQUIRED on Vercel (many serverless instances): without them the cap and rate
# limit fall back to per-instance in-memory/file state, which is correct only on
# a single always-on instance — so on Vercel the $100 cap is NOT reliably
# enforced. Create a free DB at https://upstash.com and paste both.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL  (all have safe defaults — leave unset unless you specifically need them)
# ─────────────────────────────────────────────────────────────────────────────

# Extra origins allowed to call /api/chat (comma-separated). The deployment's own
# origin is always allowed; set this only for custom domains.
# ALLOWED_ORIGIN=https://titans.example,https://www.titans.example

# Override the read-only SQLite path. Defaults to ./data/titans.db (the snapshot
# bundled by `npm run sync-db`), falling back to the pipeline copy. Not needed
# for the standard bundled-DB deploy.
# TITANS_DB_PATH=

# Haiku price overrides for the chat spend-cap math (USD per million tokens).
# Default to current pricing: input 1.0, output 5.0. Set ONLY if Anthropic
# changes Haiku pricing, so the $100 cap stays accurate.
# HAIKU_USD_PER_MTOK_IN=1.0
# HAIKU_USD_PER_MTOK_OUT=5.0
